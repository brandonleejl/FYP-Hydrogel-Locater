    "import os\n",
    "import cv2\n",
    "import numpy as np\n",
    "import pandas as pd\n",
    "import tensorflow as tf\n",
    "from tqdm import tqdm # This gives us a nice progress bar!\n",
    "\n",
    "# --- 1. Define Your Paths ---\n",
    "# UPDATE THIS PATH to match wherever you just uploaded your 1000 new photos\n",
    "NEW_IMAGES_DIR = '/kaggle/input/datasets/brandonleejl/fyp-image-only-05032026/FYP All Images Only' \n",
    "\n",
    "MODEL_PATH = '/kaggle/working/unet_gel_finder.keras'\n",
    "OUTPUT_CSV = '/kaggle/working/Final_pH_Dataset.csv'\n",
    "OUTPUT_MASKS_DIR = '/kaggle/working/ai_generated_masks'\n",
    "\n",
    "# Create a folder to save the AI's masks just in case you want to inspect them later\n",
    "os.makedirs(OUTPUT_MASKS_DIR, exist_ok=True)\n",
    "\n",
    "# --- 2. Load the Trained AI ---\n",
    "print(\"Loading U-Net 'Finder' model...\")\n",
    "unet_model = tf.keras.models.load_model(MODEL_PATH)\n",
    "\n",
    "# --- 3. The Chemistry Extraction Engine ---\n",
    "def extract_chemistry(image_path, filename):\n",
    "    # Load raw image\n",
    "    img_raw = cv2.imread(image_path)\n",
    "    if img_raw is None:\n",
    "        return None\n",
    "    \n",
    "    orig_h, orig_w = img_raw.shape[:2]\n",
    "    \n",
    "    # Resize for the AI to process (224x224)\n",
    "    img_rgb = cv2.cvtColor(img_raw, cv2.COLOR_BGR2RGB)\n",
    "    img_resized = cv2.resize(img_rgb, (224, 224))\n",
    "    input_tensor = np.expand_dims(img_resized / 255.0, axis=0)\n",
    "    \n",
    "    # AI predicts the mask\n",
    "    pred_mask = unet_model.predict(input_tensor, verbose=0)[0]\n",
    "    binary_mask = np.where(pred_mask > 0.5, 1.0, 0.0)\n",
    "    \n",
    "    # Resize the AI's mask back to the massive original photo size\n",
    "    # INTER_NEAREST ensures the mask stays purely 0 or 1, with no blurry grey edges\n",
    "    full_size_mask = cv2.resize(binary_mask, (orig_w, orig_h), interpolation=cv2.INTER_NEAREST)\n",
    "    \n",
    "    # Save the generated mask to the working folder\n",
    "    cv2.imwrite(os.path.join(OUTPUT_MASKS_DIR, filename), (full_size_mask * 255).astype(np.uint8))\n",
    "    \n",
    "    # Extract color channels from the original raw, high-res image\n",
    "    blue, green, red = cv2.split(img_raw)\n",
    "    \n",
    "    # Filter out only the pixels where the mask is active\n",
    "    valid_green = green[full_size_mask == 1.0]\n",
    "    valid_red = red[full_size_mask == 1.0]\n",
    "    \n",
    "    if len(valid_red) == 0:\n",
    "        return None # Failsafe: AI didn't find any gel\n",
    "        \n",
    "    # Calculate Medians (This mathematically deletes the UV glare and dark shadows!)\n",
    "    median_g = np.median(valid_green)\n",
    "    median_r = np.median(valid_red)\n",
    "    \n",
    "    # Prevent division by zero just in case\n",
    "    if median_r == 0:\n",
    "        return None\n",
    "        \n",
    "    # Calculate the crucial FITC/R6G ratio\n",
    "    ratio = median_g / median_r\n",
    "    \n",
    "    return {\n",
    "        'Filename': filename,\n",
    "        'Median_Green_FITC': median_g,\n",
    "        'Median_Red_R6G': median_r,\n",
    "        'Green_Red_Ratio': ratio\n",
    "    }\n",
    "\n",
    "# --- 4. Run the Mass Pipeline ---\n",
    "all_files = sorted(os.listdir(NEW_IMAGES_DIR))\n",
    "image_names = [f for f in all_files if f.upper().endswith(('.PNG', '.JPG', '.JPEG'))]\n",
    "\n",
    "print(f\"Found {len(image_names)} new images. Starting extraction...\")\n",
    "\n",
    "results = []\n",
    "for img_name in tqdm(image_names, desc=\"Processing Images\"):\n",
    "    img_path = os.path.join(NEW_IMAGES_DIR, img_name)\n",
    "    data = extract_chemistry(img_path, img_name)\n",
    "    if data:\n",
    "        results.append(data)\n",
    "\n",
    "# --- 5. Export to CSV ---\n",
    "df = pd.DataFrame(results)\n",
    "df.to_csv(OUTPUT_CSV, index=False)\n",
    "print(f\"\\nSuccess! Extracted chemical data saved to: {OUTPUT_CSV}\")"
   ]
