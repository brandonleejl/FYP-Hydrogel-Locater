    "import os\n",
    "import json\n",
    "import numpy as np\n",
    "import cv2\n",
    "import glob\n",
    "\n",
    "# 1. Define your paths\n",
    "# Assuming your JSONs are in the 'masks' folder of your input dataset\n",
    "JSON_DIR = '/kaggle/input/datasets/brandonleejl/fyp-hydrogel-locater-trainer/FYP Images Masks Only/FYP Images Masks Only' \n",
    "OUTPUT_MASKS_DIR = '/kaggle/working/converted_masks'\n",
    "\n",
    "# Create the folder to hold the new mask images\n",
    "os.makedirs(OUTPUT_MASKS_DIR, exist_ok=True)\n",
    "\n",
    "# Find all JSON files\n",
    "json_files = glob.glob(os.path.join(JSON_DIR, '*.json'))\n",
    "print(f\"Found {len(json_files)} Labelme JSON files. Starting conversion...\")\n",
    "\n",
    "converted_count = 0\n",
    "\n",
    "for json_file in json_files:\n",
    "    try:\n",
    "        # Load the JSON data\n",
    "        with open(json_file, 'r') as f:\n",
    "            data = json.load(f)\n",
    "            \n",
    "        # Get the dimensions of the original image\n",
    "        height = data['imageHeight']\n",
    "        width = data['imageWidth']\n",
    "        \n",
    "        # Create a pure black background\n",
    "        mask = np.zeros((height, width), dtype=np.uint8)\n",
    "        \n",
    "        # Loop through every polygon you drew in Labelme for this image\n",
    "        for shape in data['shapes']:\n",
    "            # Extract the points and format them for OpenCV\n",
    "            points = np.array(shape['points'], dtype=np.int32)\n",
    "            # Draw the polygon and fill it with pure white (255)\n",
    "            cv2.fillPoly(mask, [points], 255)\n",
    "            \n",
    "        # Create the new filename (e.g., IMG_6023.json -> IMG_6023.PNG)\n",
    "        base_name = os.path.basename(json_file).replace('.json', '.PNG')\n",
    "        output_path = os.path.join(OUTPUT_MASKS_DIR, base_name)\n",
    "        \n",
    "        # Save the new mask image\n",
    "        cv2.imwrite(output_path, mask)\n",
    "        converted_count += 1\n",
    "        \n",
    "    except Exception as e:\n",
    "        print(f\"Error converting {os.path.basename(json_file)}: {e}\")\n",
    "\n",
    "print(f\"\\nSuccess! Converted {converted_count} JSON files into image masks.\")\n",
    "print(f\"Saved to: {OUTPUT_MASKS_DIR}\")"
   ]
  },
